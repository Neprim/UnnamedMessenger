PORT=3000
NODE_ENV=production
URL=https://your-domain-or-server-address:3000
CORS_ORIGIN=https://your-domain-or-server-address:3000
DEV_FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-before-production
SSL_KEY_PATH=ssl/server.key
SSL_CERT_PATH=ssl/server.crt
BODY_PARSER_LIMIT=100mb
MAX_ACCOUNTS_PER_IP=3
DEFAULT_FILE_QUOTA_BYTES=104857600
MAX_UPLOAD_BYTES=104857600
MAX_PLACEHOLDER_BYTES=10240
MAX_MESSAGE_LENGTH=8000
MAX_USERNAME_LENGTH=30
AVATAR_MAX_BYTES=5242880
AVATAR_MIN_SIZE=128
AVATAR_MAX_SIZE=2048
AVATAR_MAX_RATIO=4
AVATAR_STORAGE_SIZE=256
